strict-peer-dependencies=false
auto-install-peers=false
# Install native binaries for both Apple Silicon and Rosetta (x64). Avoids esbuild/SWC
# failures when a terminal or tool runs Node under a different arch than `pnpm install`.
supportedArchitectures.os[]=current
supportedArchitectures.cpu[]=arm64
supportedArchitectures.cpu[]=x64
