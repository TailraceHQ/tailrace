{
  "name": "@tailrace/core",
  "version": "0.2.1",
  "description": "Agent data governance core: detection, policy engine, vault, audit. Zero runtime deps; runs on Node, Cloudflare Workers, and Vercel Edge.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/TailraceHQ/tailrace/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "schemas",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "@tailrace/core (esm, gzip)",
      "path": "dist/index.js",
      "limit": "60 KB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@size-limit/preset-small-lib": "^11.1.6",
    "ajv": "^8.20.0",
    "fast-check": "^4.9.0",
    "size-limit": "^11.1.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
