{
  "name": "@tailrace/cloudflare-agents",
  "version": "0.2.1",
  "description": "Tailrace helpers for Cloudflare Agents / AIChatAgent (Compose: uses @tailrace/ai-sdk).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/cloudflare-agents"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailrace/adapter": "workspace:*",
    "@tailrace/ai-sdk": "workspace:*",
    "@tailrace/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5",
    "agents": ">=0.17.0"
  },
  "peerDependenciesMeta": {
    "agents": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@ai-sdk/provider": "2.0.3",
    "ai": "^5.0.210",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  }
}
