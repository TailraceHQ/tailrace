{
  "name": "@tailrace/ai-sdk",
  "version": "0.2.1",
  "description": "Tailrace middleware for the Vercel AI SDK: model wrapper + tool wrapper.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/ai-sdk"
  },
  "homepage": "https://github.com/TailraceHQ/tailrace/tree/main/packages/ai-sdk#readme",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.testd.json"
  },
  "dependencies": {
    "@tailrace/adapter": "workspace:*",
    "@tailrace/core": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@ai-sdk/provider": "2.0.3",
    "ai": "^5.0.210",
    "expect-type": "^1.4.0",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  }
}
