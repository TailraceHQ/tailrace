{
  "name": "@tailrace/http",
  "version": "0.1.0",
  "description": "Shared Tailrace OpenAI-compatible HTTP pipeline: body helpers, SSE, 422. No host peers.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/http"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailrace/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "vitest": "^2.1.9"
  }
}
