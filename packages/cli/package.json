{
  "name": "@tailrace/cli",
  "version": "0.2.1",
  "description": "The `tailrace` CLI: create, init, scan, install-hooks, and the Claude Code hook handler.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/cli"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "tailrace": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailrace/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
