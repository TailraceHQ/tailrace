{
  "name": "@tailrace/adapter",
  "version": "0.2.3",
  "description": "Shared Tailrace integration helpers: wrapToolExecute, runGoverned. No host peers.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/adapter"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.testd.json"
  },
  "dependencies": {
    "@tailrace/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "expect-type": "^1.4.0",
    "fast-check": "^4.9.0",
    "vitest": "^2.1.9"
  }
}
