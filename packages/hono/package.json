{
  "name": "@tailrace/hono",
  "version": "0.1.4",
  "description": "Tailrace Hono middleware: OpenAI-compatible passthrough with policy at the model boundary.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/hono"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailrace/core": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "hono": "^4.12.30",
    "vitest": "^2.1.9"
  }
}
