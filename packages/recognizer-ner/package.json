{
  "name": "@tailrace/recognizer-ner",
  "version": "0.2.0",
  "description": "Optional Tier 1 NER recognizer for Tailrace (Privacy Filter ONNX). Node only.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/recognizer-ner"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tailrace/core": "workspace:*",
    "js-tiktoken": "^1.0.21"
  },
  "peerDependencies": {
    "onnxruntime-node": ">=1.18"
  },
  "peerDependenciesMeta": {
    "onnxruntime-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
