{
  "name": "@tailrace/trpc",
  "version": "0.1.0",
  "description": "Tailrace tRPC procedure middleware: tool-boundary scanning for input/output.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TailraceHQ/tailrace.git",
    "directory": "packages/trpc"
  },
  "homepage": "https://tailrace.dev",
  "bugs": {
    "url": "https://github.com/TailraceHQ/tailrace/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.testd.json"
  },
  "dependencies": {
    "@tailrace/adapter": "workspace:*",
    "@tailrace/core": "workspace:*"
  },
  "peerDependencies": {
    "@trpc/server": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@trpc/server": "^11.4.3",
    "expect-type": "^1.4.0",
    "vitest": "^2.1.9",
    "zod": "^3.25.76"
  }
}
