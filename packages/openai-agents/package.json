{
  "name": "@tailrace/openai-agents",
  "version": "0.1.0",
  "description": "Tailrace wrappers for OpenAI Agents SDK function tools.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.testd.json"
  },
  "dependencies": {
    "@tailrace/adapter": "workspace:*",
    "@tailrace/core": "workspace:*"
  },
  "peerDependencies": {
    "@openai/agents": ">=0.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@openai/agents": "^0.3.9",
    "expect-type": "^1.4.0",
    "vitest": "^2.1.9",
    "zod": "^4.4.3"
  }
}
